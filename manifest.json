{
  "manifest_version": 3,
  "name": "ASM Label Generator",
  "version": "3.3.0",
  "description": "Generate labels from Factory.app orders and delivery dockets",
  "permissions": ["activeTab", "storage", "scripting"],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.factory.app/*"],
      "js": ["factory-scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["generator.html", "sandbox.html", "bridge.js", "lib/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
